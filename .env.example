# Email Configuration
# Choose email mode: 'api' (default, cloud service) or 'smtp' (self-hosted)
EMAIL_MODE=api

# ===== API Mode Configuration (Default - No Setup Required) =====
# When using API mode, emails are sent via cloud service
# Optional: Use custom API endpoint
# API_URL=https://your-app.vercel.app/api/send-calendar
# API_KEY=your-api-key  # Only if API requires authentication

# ===== SMTP Mode Configuration (Self-Hosted Email) =====
# Uncomment and configure if using EMAIL_MODE=smtp

# SMTP Server Settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# SMTP Authentication
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password

# Note: Copy this file to .env and update with your actual credentials
# For GitHub Actions, configure these as repository secrets
