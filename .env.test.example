# Test Configuration Example
# Copy to .env.test and fill in your test credentials

# NBT Test Credentials
TEST_STUDENT_ID=your-student-id
TEST_PASSWORD=your-password

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sender@example.com
SMTP_PASS=your-smtp-password
